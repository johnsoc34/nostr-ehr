# FHIR REST API Configuration
# Copy to .env and fill in your values

PORT=3005

# Practice Nostr secret key (hex) — decrypts all patient records
# CRITICAL: Keep this secure. chmod 600 this file.
PRACTICE_SK_HEX=

# Practice public key (hex)
PRACTICE_PK_HEX=your_practice_pubkey_hex_64chars

# Relay WebSocket URL
RELAY_URL=wss://relay.yourpractice.com

# API key management database path
KEYS_DB_PATH=/var/lib/immutable-health/fhir-keys.db

# Admin password for key management (SHA-256 hash)
# Generate with: echo -n "your_password" | sha256sum | cut -d' ' -f1
ADMIN_PASSWORD_HASH=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://billing.yourpractice.com
