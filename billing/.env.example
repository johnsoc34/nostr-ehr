# Billing Dashboard Configuration
# Copy to .env and fill in your values

PORT=3002

# SQLite database path
DATABASE_PATH=/var/lib/immutable-health/billing.db

# Dashboard login password (SHA-256 hash)
# Generate with: echo -n "your_password" | sha256sum | cut -d' ' -f1
DASHBOARD_PASSWORD_HASH=

# Nostr practice secret key (nsec format) — for sending NIP-17 invoice DMs
NOSTR_NSEC=nsec1...

# Relay WebSocket URL
RELAY_URL=wss://relay.yourpractice.com

# Resend email API (for email invoices)
RESEND_API_KEY=re_...
RESEND_FROM=billing@yourpractice.com

# Practice info (displayed in invoices)
PRACTICE_NAME=Your Practice Name

# Monthly membership fee in cents (e.g., 15000 = $150.00)
MONTHLY_FEE_CENTS=15000

# Public URL for this billing dashboard (used in invoice payment links)
BILLING_URL=https://billing.yourpractice.com
PORTAL_URL=https://portal.yourpractice.com
NEXT_PUBLIC_PRACTICE_NAME=Your Practice Name
