# NostrEHR — Environment Configuration
# Copy this file to .env.local and fill in your practice values.

# ─── Required ──────────────────────────────────────────────────────────────────
# Your Nostr relay URL (WebSocket)
NEXT_PUBLIC_RELAY_URL=wss://relay.example.com

# Practice Nostr public key (hex format, 64 characters)
NEXT_PUBLIC_PRACTICE_PUBKEY=

# Practice display name
NEXT_PUBLIC_PRACTICE_NAME=My Practice

# ─── Service URLs (set these if you're running the full stack) ─────────────────
# Patient portal URL
NEXT_PUBLIC_PORTAL_URL=https://portal.example.com

# Billing dashboard URL
NEXT_PUBLIC_BILLING_URL=https://billing.example.com

# Calendar/scheduling URL
NEXT_PUBLIC_CALENDAR_URL=https://calendar.example.com

# Blossom file server URL (NIP-B7)
NEXT_PUBLIC_BLOSSOM_URL=https://blossom.example.com

# ─── Telehealth (optional) ────────────────────────────────────────────────────
# TURN server hostname for WebRTC NAT traversal
NEXT_PUBLIC_TURN_HOST=turn.example.com
NEXT_PUBLIC_TURN_USER=
NEXT_PUBLIC_TURN_CRED=

# ─── Practice Info (used in PDF generation) ──────────────────────────────────
NEXT_PUBLIC_PRACTICE_ADDRESS=123 Main Street, Suite 100
NEXT_PUBLIC_PRACTICE_CITY_STATE_ZIP=Austin, TX 78701
NEXT_PUBLIC_PRACTICE_PHONE=(512) 555-0100
NEXT_PUBLIC_PRACTICE_FAX=(512) 555-0101
NEXT_PUBLIC_PRACTICE_PROVIDER=Dr. J, DO
