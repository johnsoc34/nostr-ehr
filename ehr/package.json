{
  "name": "nostr-ehr",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "description": "NostrEHR — Sovereign Pediatric Electronic Health Records",
  "author": "NostrEHR Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --win",
    "electron:build:mac": "next build && electron-builder --mac",
    "electron:build:linux": "next build && electron-builder --linux",
    "electron:build:optimized": "node electron-build.js"
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "next": "^14.2.0",
    "nostr-tools": "^2.10.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nostrehr.app",
    "productName": "NostrEHR",
    "copyright": "Copyright © 2026 NostrEHR Contributors",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "package.json",
        "to": "resources/app/package.json"
      }
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "nextapp",
        "filter": [
          "package.json",
          "next.config.*",
          ".next/**/*",
          "public/**/*",
          "src/**/*",
          "node_modules/**/*",
          ".env.local"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.png",
      "artifactName": "NostrEHR-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NostrEHR"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.medical",
      "icon": "electron/icon.png",
      "artifactName": "NostrEHR-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "icon": "electron/icon.png",
      "artifactName": "NostrEHR-${version}.${ext}"
    }
  }
}